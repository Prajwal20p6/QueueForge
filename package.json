{
  "name": "queueforge",
  "version": "1.0.0",
  "description": "Enterprise-grade event-driven task result delivery pipeline built with TypeScript, Node.js, BullMQ, PostgreSQL, and Redis",
  "repository": {
    "type": "git",
    "url": "https://github.com/Prajwal20p6/QueueForge.git"
  },
  "author": "Prajwal",
  "license": "MIT",
  "keywords": [
    "task-queue",
    "job-queue",
    "bullmq",
    "redis",
    "postgresql",
    "typescript",
    "node.js",
    "event-driven",
    "microservices",
    "distributed-systems"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "start:prod": "npx prisma generate && npx prisma db push || echo '[Render/Cloud] Database connection pending. Ensure DATABASE_URL is set in environment.' && node dist/index.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:unit": "jest --testPathPattern=tests/unit --runInBand",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "test:chaos": "jest --testPathPattern=tests/chaos --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'build', 'coverage'].forEach(d => fs.rmSync(d, {recursive: true, force: true}))\"",
    "migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts",
    "docker:build": "docker build -t queueforge .",
    "dashboard:dev": "cd src/frontend && npm run dev",
    "dashboard:build": "cd src/frontend && npm run build"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.47.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/instrumentation": "^0.52.1",
    "@opentelemetry/instrumentation-express": "^0.41.0",
    "@opentelemetry/instrumentation-http": "^0.52.1",
    "@opentelemetry/instrumentation-pg": "^0.44.0",
    "@opentelemetry/instrumentation-redis": "^0.39.0",
    "@opentelemetry/resources": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.221.0",
    "@opentelemetry/sdk-trace-node": "^1.25.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "@prisma/client": "^5.16.1",
    "axios": "^1.7.2",
    "bullmq": "^5.8.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "opossum": "^8.1.3",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "prom-client": "^15.1.2",
    "rate-limit": "^0.1.1",
    "redis": "^5.0.0",
    "typescript": "^5.5.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/opossum": "^8.1.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "prisma": "^5.16.1",
    "supertest": "^7.0.0",
    "testcontainers": "^10.9.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
