# Server Config
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/queueforge?schema=public"

# Cache & Message Broker (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# Authentication & Security
JWT_SECRET="super-secret-jwt-key-change-this-in-production"
API_KEY="qf_secret_api_key_12345"
API_KEY_SECRET="api_key_secret_key_secret_key_secret_key_secret_key"
WEBHOOK_HMAC_SECRET="webhook_signing_secret_key_12345"
HMAC_SECRET="hmac_secret_key_secret_key_secret_key_secret_key_secret_key"

# OpenTelemetry Monitoring
OTEL_SERVICE_NAME="queueforge-pipeline"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
