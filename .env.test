# Test Server Configuration
NODE_ENV=test
PORT=3001
LOG_LEVEL=error

# Test Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/queueforge_test?schema=public"

# Test Cache & Message Broker Configuration
REDIS_URL="redis://localhost:6379"

# Test Security and Secrets (must be 32+ characters)
API_KEY_SECRET="test-secret-key-min-32-characters-long"
JWT_SECRET="test-jwt-secret-min-32-characters-long"
HMAC_SECRET="test-hmac-secret-min-32-characters-long"

# Observability Configuration (disabled in test)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT="http://localhost:14268/api/traces"
APP_NAME=QueueForge
APP_VERSION=1.0.0
ENVIRONMENT=test

# Resilience & Timeouts (small limits for faster execution)
MAX_RETRIES=3
BACKOFF_BASE_MS=100
CIRCUIT_BREAKER_THRESHOLD=50
CIRCUIT_BREAKER_TIMEOUT_MS=1000
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Connection Dimensions
DB_POOL_MIN=1
DB_POOL_MAX=5
REDIS_POOL_MIN=1
REDIS_POOL_MAX=5
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=100
STALE_JOB_TIMEOUT_MS=5000
HEARTBEAT_INTERVAL_MS=2000
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=7
OTEL_TRACE_SAMPLE_RATE=0.0
